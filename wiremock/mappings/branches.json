{
  "mappings": [
    {
      "name": "GET /branches/{uuid} - resolve vendor_uuid for known branches",
      "metadata": {
        "wiremock-gui": {
          "folder": "/branch/resolve-vendor"
        }
      },
      "priority": 2,
      "request": {
        "method": "GET",
        "urlPathPattern": "/branches/[0-9a-f-]{36}"
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "jsonBody": {
          "vendor_uuid": "c079081e-ae88-40b3-8ee0-fbcca008899c"
        }
      }
    },

    {
      "name": "GET /branches/{uuid} - 404 for unknown branch (00000000-0000-0000-0000-000000000000)",
      "metadata": {
        "wiremock-gui": {
          "folder": "/branch/resolve-vendor"
        }
      },
      "priority": 1,
      "request": {
        "method": "GET",
        "urlPath": "/branches/00000000-0000-0000-0000-000000000000"
      },
      "response": {
        "status": 404,
        "headers": { "Content-Type": "application/json" },
        "jsonBody": {
          "message": "Branch not found."
        }
      }
    },

    {
      "name": "POST /vendors/{uuid}/branches - create branch",
      "metadata": {
        "wiremock-gui": {
          "folder": "/branch/create"
        }
      },
      "request": {
        "method": "POST",
        "urlPathPattern": "/vendors/[0-9a-f-]{36}/branches"
      },
      "response": {
        "status": 201,
        "headers": { "Content-Type": "application/json" },
        "jsonBody": {
          "uuid": "{{jsonPath request.body '$.uuid'}}",
          "name": "{{jsonPath request.body '$.name'}}",
          "telephone": "{{jsonPath request.body '$.telephone'}}",
          "email": "{{jsonPath request.body '$.email'}}",
          "is_active": true,
          "responsible_person": null,
          "address": {
            "street": "{{jsonPath request.body '$.address.street'}}",
            "city": "{{jsonPath request.body '$.address.city'}}",
            "postcode": "{{jsonPath request.body '$.address.postcode'}}",
            "country_code": "{{jsonPath request.body '$.address.country_code'}}"
          }
        }
      }
    },

    {
      "name": "PUT /vendors/{uuid}/branches/{uuid} - update branch",
      "metadata": {
        "wiremock-gui": {
          "folder": "/branch/update"
        }
      },
      "request": {
        "method": "PUT",
        "urlPathPattern": "/vendors/[0-9a-f-]{36}/branches/[0-9a-f-]{36}"
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "jsonBody": {
          "uuid": "{{request.pathSegments.[3]}}",
          "name": "{{jsonPath request.body '$.name'}}",
          "telephone": "{{jsonPath request.body '$.telephone'}}",
          "email": "{{jsonPath request.body '$.email'}}",
          "is_active": true,
          "responsible_person": null,
          "address": {
            "street": "{{jsonPath request.body '$.address.street'}}",
            "city": "{{jsonPath request.body '$.address.city'}}",
            "postcode": "{{jsonPath request.body '$.address.postcode'}}",
            "country_code": "{{jsonPath request.body '$.address.country_code'}}"
          }
        }
      }
    },

