# This file exists only to document expected env vars.
# When deployed via Coolify, environment is managed in the Coolify UI.
# When run locally, no env vars are required — services bind to their default container ports
# and you reach them via `docker compose port wiremock 8089` / `... 8080` / `... 1025` / `... 8025`.

# To expose host ports locally, override via a `docker-compose.override.yml`:
#
#   services:
#     wiremock:
#       ports:
#         - "8088:8089"
#         - "8087:8080"
#     mailhog:
#       ports:
#         - "1025:1025"
#         - "8025:8025"